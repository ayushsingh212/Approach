# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=

# ── Auth (NextAuth) ────────────────────────────────────────────────────────────
# NEXTAUTH_URL must be the exact production URL (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ── Supabase (file uploads) ───────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── LinkedIn Email Scraper Extension ──────────────────────────────────────────
# Must match the API_KEY constant at the top of chrome-extension/background.js
SCRAPER_API_KEY=

# ── Vercel Cron protection ────────────────────────────────────────────────────
CRON_SECRET=

# ── AI Email Importer (OpenRouter) ──────────────────────────────────────────────
# Get your free key at: https://openrouter.ai → API Keys
OPENROUTER_API_KEY=
