{
  "manifest_version": 3,
  "name": "Approach Lead Gen Agent",
  "version": "2.0.0",
  "description": "AI-powered tech company lead discovery and email extraction.",
  "permissions": [
    "activeTab",
    "alarms",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://*/*",
    "https://approach-two.vercel.app/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*", "https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Approach Agent"
  }
}
